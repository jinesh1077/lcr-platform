{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://carrier-optimization.local/schemas/cdr-event.json",
  "title": "CDREvent",
  "type": "object",
  "required": ["call_id", "dialed_number", "carrier_id", "duration_sec", "answered", "timestamp"],
  "properties": {
    "call_id": { "type": "string", "format": "uuid" },
    "dialed_number": { "type": "string", "pattern": "^[0-9]+$" },
    "carrier_id": { "type": "string" },
    "duration_sec": { "type": "integer", "minimum": 0 },
    "answered": { "type": "boolean" },
    "disconnect_reason": { "type": "string" },
    "timestamp": { "type": "string", "format": "date-time" },
    "cost_theoretical": { "type": "number", "minimum": 0 }
  }
}
